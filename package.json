{
  "name": "@lickle/bin",
  "version": "0.3.0-dev.1",
  "description": "A tiny, efficient utility for defining binary data schemas and performing encoding/decoding of JavaScript objects to and from Uint8Array",
  "author": "Dan Beaven <dm.beaven@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pingid/lickle-bin.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "lib/cjs/index.js",
  "types": "lib/ts/index.d.ts",
  "module": "lib/esm/index.js",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./lib/ts/index.d.ts",
      "import": "./lib/esm/index.js",
      "require": "./lib/cjs/index.js"
    }
  },
  "files": [
    "lib",
    "README.md",
    "package.json",
    "!**/*.test.*"
  ],
  "keywords": [
    "binary",
    "encoding",
    "decoding",
    "codec",
    "serialization",
    "schema",
    "bincode",
    "protobuf"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "rm -rf lib",
    "build": "npm run typecheck && npm run esm && npm run cjs && npm run pkg",
    "format": "prettier --write .",
    "esm": "tsc -p ./tsconfig.esm.json",
    "cjs": "tsc -p ./tsconfig.cjs.json",
    "pkg": "node -e \"require('fs').writeFileSync('lib/cjs/package.json', JSON.stringify({type:'commonjs'}))\" && node -e \"require('fs').writeFileSync('lib/esm/package.json', JSON.stringify({type:'module'}))\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "bench": "tsx bench/bench.ts",
    "bench:save": "tsx bench/cmp.ts save",
    "bench:diff": "tsx bench/cmp.ts diff",
    "sync-version": "node scripts/sync-version.mjs",
    "version": "npm run sync-version && git add jsr.json",
    "prepublishOnly": "npm run sync-version && npm run clean && npm run build"
  },
  "devDependencies": {
    "@mitata/counters": "^0.0.8",
    "@types/node": "^25.8.0",
    "esbuild": "^0.28.0",
    "fast-check": "^4.8.0",
    "jsr": "^0.14.3",
    "mitata": "^1.0.34",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 120,
    "trailingComma": "all"
  }
}
